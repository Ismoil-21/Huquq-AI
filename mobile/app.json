{
  "expo": {
    "name": "Huquq AI",
    "slug": "huquq-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0F1E"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "uz.huquq.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSUserNotificationUsageDescription": "Huquqiy maslahat yangiliklari va limit haqida xabar olish uchun",
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0F1E"
      },
      "package": "uz.huquq.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0AD4B1",
          "sounds": [],
          "mode": "production"
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://huquq-ai-fpa2.onrender.com/api",
      "eas": {
        "projectId": "b5591f21-74c6-46f4-87d5-ec1879cf2942"
      }
    },
    "owner": "ismoiltohirov"
  }
}
